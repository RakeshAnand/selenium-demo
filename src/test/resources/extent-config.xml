<extentreports>
    <configuration>
        <!-- Theme -->
        <theme>dark</theme>

        <!-- Branding -->
        <reportName>Selenium Demo Automation Report</reportName>
        <documentTitle>Selenium Demo Test Execution</documentTitle>

        <!-- Chart visibility -->
        <enableTimeline>true</enableTimeline>
        <enableDashboard>true</enableDashboard>

        <!-- Custom CSS -->
        <css>
            .badge-primary { background-color: #4CAF50; }
            .nav-wrapper { background-color: #1E1E1E; }
        </css>

        <!-- Custom JS -->
        <js>
            console.log("Extent Report Loaded - Customized for Selenium Demo");
        </js>
    </configuration>
</extentreports>
